;;    (box :class "notifications"
;;         :visible {notification_count > 0}
;;      (label :text " ${notification_count}"))))


(defvar calen_rev false)
(defwindow calen
  :monitor 0
  :geometry (geometry :x "1600px" :y "0px" :width "0px" :height "0px":anchor "left top")
  :stacking "fg"
  :exclusive false
  :focusable false
  :wm-ignore true
  :namespace "eww_main"
  (box :space-evenly false
         (revealer :transition "slidedown"
                   :reveal calen_rev
                   :duration "350ms"
                   (clock_expanded :class "calen"
                    ))))

(defpoll timehour
  :interval "1s"
  :initial "timedate"
  `date +%H`)
(defpoll timeday
  :interval "1s"
  :initial 1
  `date +%d`)

(defpoll timemin
  :interval "1s"
  :initial "timedate"
  `date +%M`)

(defpoll timesec
  :interval "1s"
  :initial "timedate"
  `date +%S`)

(defwidget clock_expanded []
  (box :space-evenly false :spacing 10 :orientation "v" :halign "fill"
    (label :text "${timehour}:${timemin}:${timesec}" :class "clock_expanded-time")
    (calendar :class "calen_in" :day timeday)))



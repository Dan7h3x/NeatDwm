#!/usr/bin/env bash

bat=$(cat /sys/class/power_supply/BAT*/capacity)
stat=$(cat /sys/class/power_supply/BAT*/status)
if [ "$stat" == "Charging" ]; then
  icon="ó°‚„ "
  class="bat-green"
  background="#308052"
  foreground="#6ec687"
elif [ $bat -ge 90 ]; then
  icon="ď•¸"
  class="bat-green"
  background="#308052"
  foreground="#6ec687"
elif [ $bat -ge 80 ]; then
  icon="ď–€"
  class="bat-green"
  background="#308052"
  foreground="#6ec687"
elif [ $bat -ge 70 ]; then
  icon="ď•ż"
  class="bat-green"
  background="#308052"
  foreground="#6ec687"
elif [ $bat -ge 60 ]; then
  icon="ď•ľ"
  class="bat-green"

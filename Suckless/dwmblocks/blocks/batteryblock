  foreground="#6ec687"
elif [ $bat -ge 50 ]; then
  icon="ď•˝"
  class="bat-green"
  background="#308052"
  foreground="#6ec687"
elif [ $bat -ge 40 ]; then
  icon="ď•Ľ"
  class="bat-green"
  background="#308052"
  foreground="#6ec687"
elif [ $bat -ge 30 ]; then
  icon="ď•»"

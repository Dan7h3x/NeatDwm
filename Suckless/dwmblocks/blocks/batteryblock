  foreground="#df5b61"
else
  icon="ď•ą"
  class="bat-red"
  background="#c4373d"
  foreground="#df5b61"
fi

if [[ $1 == '--icon' ]]; then
  echo $icon
elif [[ $1 == '--bg' ]]; then
  echo $background
elif [[ $1 == '--fg' ]]; then
  echo $foreground
elif [[ $1 == '--class' ]]; then
  echo $class
elif [[ $1 == '--val' ]]; then
  echo $bat
fi


if [[ ! $(acpi -b | grep -i battery) ]]; then
  exit 0
else
  if [[ ! $(acpi -a | grep -i adapter | grep -i on-line) ]]; then
    printf "^b$black^^c$foreground^$icon^d^"
  else
    printf "^b$black^^c$foreground^$icon^d^"
  fi
  echo "^b$foreground^^c$black^$(acpi | sed "s/,//g" | awk '{print $4}' | tr -d "\n")^d^"
fi
